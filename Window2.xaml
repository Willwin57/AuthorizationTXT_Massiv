<Window x:Class="WpfApp5.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5"
        mc:Ignorable="d"
        Title="Window2" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20" VerticalAlignment="Center">

            <TextBlock Text="Первое число:" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNum1" Height="25" Margin="0,0,0,10" />

            <TextBlock Text="Знак (+, -, *, /):" Margin="0,0,0,5"/>
            <TextBox x:Name="txtSign" Height="25" Margin="0,0,0,10" MaxLength="1" />

            <TextBlock Text="Второе число:" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNum2" Height="25" Margin="0,0,0,15" />

            <Button x:Name="btnCalc" Content="Посчитать" Height="30" Click="btnCalc_Click" />

        </StackPanel>
    </Grid>
</Window>
